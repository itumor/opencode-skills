prefix_rule(pattern=["opencode"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "https://opencode.ai/zen/v1/models"], decision="allow")
prefix_rule(pattern=["curl", "-sS", "https://opencode.ai/zen/v1/chat/completions"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/hermes", "config", "set", "model.provider", "opencode-zen"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "config", "set", "model.provider", "opencode-zen"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "config", "set", "model.default", "minimax-m2.5-free"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "config", "set", "model.api_key", "no-key-required"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "-z", "Reply with exactly: ok", "--toolsets", "none"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "-z", "Reply with exactly: ok"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "config", "set", "OPENCODE_ZEN_API_KEY", "no-key-required"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "-z", "Say hi in one short sentence."], decision="allow")
prefix_rule(pattern=["rg", "-o", "\"content\":\"[^\"]*\"|\"finish_reason\":\"[^\"]*\""], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "config", "set", "model.max_tokens", "1000"], decision="allow")
prefix_rule(pattern=["~/.hermes/hermes-agent/venv/bin/python3.11", "~/.hermes/hermes-agent/hermes", "chat", "-q", "Say hi in one short sentence.", "--provider", "opencode-zen", "-m", "minimax-m2.5-free", "-Q"], decision="allow")
prefix_rule(pattern=["nc", "-vz"], decision="allow")
prefix_rule(pattern=["set", "-a"], decision="allow")
prefix_rule(pattern=["source", ".env"], decision="allow")
prefix_rule(pattern=["aws", "ec2", "describe-instances"], decision="allow")
prefix_rule(pattern=["git", "worktree", "add"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "git merge --ff-only Development && git log -1 --oneline --decorate && git status --short && rg --files script | rg 'password-policy|ppm|ppolicy' && ls docs/superpowers/specs docs/superpowers/plans 2>/dev/null || true"], decision="allow")
