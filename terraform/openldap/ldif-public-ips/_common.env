# Common values (matches terraform/openldap/terraform.tfvars)
BASE_DN='dc=cae,dc=local'
ADMIN_DN='cn=admin,dc=cae,dc=local'
ADMIN_PW='admin'
REPL_DN='cn=replicator,dc=cae,dc=local'
REPL_PW='replpass'

# Symas ldapi socket on these instances:
LDAPI_URI='ldapi://%2Fvar%2Fsymas%2Frun%2Fldapi'

# DNs observed on the instances:
MODULE_DN='cn=module{0},cn=config'
DB_DN='olcDatabase={1}mdb,cn=config'
