dn: olcDatabase={1}mdb,cn=config
changetype: modify
replace: olcSyncRepl
olcSyncRepl: rid=201 provider=ldap://10.20.0.10:389 bindmethod=simple binddn="cn=replicator,dc=cae,dc=local" credentials=replpass searchbase="dc=cae,dc=local" type=refreshAndPersist retry="5 5 300 5" timeout=1 starttls=critical tls_reqcert=demand tls_cacert=/opt/symas/etc/openldap/tls/ca.crt
-
replace: olcMirrorMode
olcMirrorMode: TRUE
