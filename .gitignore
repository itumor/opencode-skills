# Skills containing credentials/bank IPs — never commit to public repo
**/nextgenopen-ldap/

# Original/backup files that may contain secrets
**/SKILL.original*
**/*.backup
**/*.bak

# Credential files
.env
*.token
token.json
credentials.json
auth.json
*.key
*.pem
*.p12
*.pfx

# Config files that may contain API keys
config.yaml
config.yaml.bak.*
config.toml
.skills_prompt_snapshot.json

# Lock files (no value)
*.lock

# Secrets manager files
secrets/
vault/

# Runtime artifacts (logs, session data, caches, databases)
sync.log
sync-cron.log
logs/
.remember/
sessions/
cache/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# macOS
.DS_Store
.AppleDouble

# Editor
*.swp
*.swo
*~
